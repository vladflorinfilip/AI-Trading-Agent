# ── Ethereum / Sepolia ────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=0xYOUR_OPERATOR_WALLET_PRIVATE_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Agent wallets ─────────────────────────────────────────────────────────────
# operatorWallet owns the ERC-721 token (can be cold wallet).
# agentWallet is the hot wallet the agent uses for signing TradeIntents + checkpoints.
# If not set, AGENT_WALLET_PRIVATE_KEY falls back to PRIVATE_KEY.
AGENT_WALLET_PRIVATE_KEY=0xYOUR_AGENT_HOT_WALLET_PRIVATE_KEY

# ── Kraken API ────────────────────────────────────────────────────────────────
# Install the Kraken CLI: https://github.com/kraken-oss/kraken-cli
KRAKEN_API_KEY=YOUR_KRAKEN_API_KEY
KRAKEN_API_SECRET=YOUR_KRAKEN_API_SECRET
KRAKEN_SANDBOX=true                         # true = paper trading, false = live
KRAKEN_CLI_PATH=kraken                      # path to CLI binary if not on PATH

# ── Deployed contract addresses ───────────────────────────────────────────────
# Auto-populated by scripts/deploy.ts
# If using hackathon-provided contracts, put their addresses here instead.
AGENT_REGISTRY_ADDRESS=
HACKATHON_VAULT_ADDRESS=
RISK_ROUTER_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
VALIDATION_REGISTRY_ADDRESS=

# ── Agent identity ────────────────────────────────────────────────────────────
# Auto-populated after running scripts/register-agent.ts
AGENT_ID=

# ── Agent config ──────────────────────────────────────────────────────────────
TRADING_PAIR=XBTUSD
POLL_INTERVAL_MS=30000
